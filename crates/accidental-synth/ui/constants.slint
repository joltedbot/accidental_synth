export global Constant {
    // Tuning range limits
    out property <int> MIN_COURSE_TUNE_SEMITONES: -12;  // oscillator-panel.slint
    out property <int> MAX_COURSE_TUNE_SEMITONES: 12;   // oscillator-panel.slint

    // Module indices
    out property <int> ENVELOPE_AMP_INDEX: 0;       // global-panel.slint
    out property <int> ENVELOPE_FILTER_INDEX: 1;     // filter-panel.slint
    out property <int> LFO_MOD_WHEEL_INDEX: 0;      // global-panel.slint
    out property <int> LFO_FILTER_INDEX: 1;          // filter-panel.slint

    out property <int> OSCILLATOR_SUB_INDEX: 0;      // oscillator-panel.slint, global-panel.slint
    out property <int> OSCILLATOR_ONE_INDEX: 1;      // oscillator-panel.slint, global-panel.slint
    out property <int> OSCILLATOR_TWO_INDEX: 2;      // oscillator-panel.slint, global-panel.slint
    out property <int> OSCILLATOR_THREE_INDEX: 3;    // oscillator-panel.slint, global-panel.slint

    // Effect sentinel
    out property <float> EFFECT_DISABLED_VALUE: -1.0; // effects.slint

    // Pitch bend range limits
    out property <int> PITCH_BEND_MINIMUM: 2;        // global-panel.slint
    out property <int> PITCH_BEND_MAXIMUM: 12;       // global-panel.slint

    // Default values still referenced as defaults in component property declarations
    out property <float> DEFAULT_BALANCE_NORMAL: 0.5;        // components.slint (BalanceSlider default)
    out property <float> DEFAULT_LFO_FREQUENCY_NORMAL: 0.1;  // components.slint (LfoControls default)

    // Enum lists for dropdown menus
    out property <[string]> OSC_WAVE_SHAPES: [       // components.slint, oscillator-panel.slint, effects.slint
        "Sine",
        "Triangle",
        "Square",
        "Saw",
        "Pulse",
        "Ramp",
        "Supersaw",
        "AM",
        "FM",
        "Noise"
    ];

    out property <[string]> SATURATION_MODES: [      // effects.slint
        "Analog Modeled",
        "Tube Like",
        "Soft Clipping",
        "Wave Shaping",
        "Sine Shaper",
        "Polynomial"
    ];
}
