import {
    Panel,
    DropDownMenu,
    VerticalSpacer,
    HorizontalControlLabel,
    GreenScreenText,
} from "components.slint";
import { Theme } from "theme.slint";
import { Button, ComboBox, HorizontalBox } from "std-widgets.slint";
import { PatchState } from "constants.slint";
import {
    SettingsIcon,
    SettingsWindow,
    AudioDevice,
    MidiPort,
    PatchStatus,
} from "settings-panel.slint";

component MidiScroller inherits Rectangle {
    in property <[string]> output;

    background: Theme.midi-scroller-background;
    border-width: 1px;
    border-color: darkgreen;
    border-radius: 6px;
    width: Theme.midi-scroller-width;
    height: Theme.midi-scroller-height;
    clip: true;

    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            padding: 6px;
            spacing: 10px;
            alignment: start;

            GreenScreenText {
                text: Theme.midi-scroller-title;
                font-size: Theme.midi-scroller-font-size;
                font-family: "HackNerdFontMono";
                letter-spacing: 0px;
                horizontal-alignment: left;
                opacity: 0.6;
            }

            // Newest first (output[3]), fades right as notes age
                GreenScreenText {
                text: output[3];
                font-size: 12px;
                font-family: "HackNerdFontMono";
                letter-spacing: 0px;
                horizontal-alignment: left;
            }

            GreenScreenText {
                text: output[2];
                font-size: 12px;
                font-family: "HackNerdFontMono";
                letter-spacing: 0px;
                horizontal-alignment: left;
                opacity: 0.65;
            }

            GreenScreenText {
                text: output[1];
                font-size: 12px;
                font-family: "HackNerdFontMono";
                letter-spacing: 0px;
                horizontal-alignment: left;
                opacity: 0.4;
            }

            GreenScreenText {
                text: output[0];
                font-size: 12px;
                font-family: "HackNerdFontMono";
                letter-spacing: 0px;
                horizontal-alignment: left;
                opacity: 0.2;
            }
        }
    }
}

export component Version inherits Text {
    in property <string> version;
    vertical-alignment: bottom;
    font-size: Theme.header-version-font-size;
    text: Theme.header-version-prefix + version;
}

export component Logo inherits Image {
    source: Theme.header-logo;
    horizontal-alignment: Theme.header-logo-alignment;
    height: Theme.header-logo-height;
    width: Theme.header-logo-width;
}

export component Patches inherits HorizontalLayout {
    in property <string> title;
    in property <[string]> patch-list;
    in property <int> selected-index;
    callback patch-changed(int);

    VerticalLayout {
        alignment: center;
        HorizontalControlLabel {
            label: "Patches";
        }
    }

    preset := ComboBox {
        height: 25px;
        width: Theme.patch-list-width;
        model: patch-list;

        selected(value) => {
            patch-changed(self.current-index);
        }
    }

    property <int> gen: PatchState.generation;
    changed gen => {
        preset.current-index = selected-index;
    }
}

export component HeaderPanel inherits Panel {
    in property <string> version;
    in property <AudioDevice> audio-device-values;
    in property <MidiPort> midi-port-values;
    in property <[string]> patch-list;
    in property <[string]> user-patch-list;
    in property <PatchStatus> patch-save-status;
    in property <PatchStatus> patch-delete-status;
    in-out property <int> selected-patch-index;
    in property <[string]> midi-display-values;
    in property <bool> polarity-is-flipped;

    callback audio-output-device-changed(string);
    callback audio-output-left-channel-changed(string);
    callback audio-output-right-channel-changed(string);
    callback audio-sample-rate-changed(string);
    callback audio-buffer-size-changed(string);
    callback midi-input-port-changed(string);
    callback midi-input-channel-changed(string);
    callback patch-changed(int);
    callback patch-saved(string);
    callback patch-deleted(string);
    callback polarity-flipped(bool);

    height: Theme.header-panel-height;
    background: Theme.header-panel-background;

    settings := SettingsWindow {
        audio-device-values: audio-device-values;
        midi-port-values: midi-port-values;
        patch-save-status: patch-save-status;
        patch-delete-status: patch-delete-status;
        user-patch-list: user-patch-list;
        polarity-is-flipped: polarity-is-flipped;

        audio-output-device-changed(device) => {
            audio-output-device-changed(device);
        }
        audio-output-left-channel-changed(left) => {
            audio-output-left-channel-changed(left);
        }
        audio-output-right-channel-changed(right) => {
            audio-output-right-channel-changed(right);
        }
        audio-sample-rate-changed(rate) => {
            audio-sample-rate-changed(rate);
        }
        audio-buffer-size-changed(size) => {
            audio-buffer-size-changed(size);
        }
        midi-input-port-changed(port) => {
            midi-input-port-changed(port);
        }
        midi-input-channel-changed(channel) => {
            midi-input-channel-changed(channel);
        }
        patch-saved(name) => {
            patch-saved(name);
        }
        patch-deleted(name) => {
            patch-deleted(name);
        }
        polarity-flipped(is_flipped) => {
            polarity-flipped(is_flipped);
        }
    }

    HorizontalLayout {

        padding: Theme.header-panel-padding;
        spacing: Theme.header-panel-spacing;

        alignment: space-between;

        logo := Logo { }

        patches := Patches {
            title: Theme.settings-patches-label;
            patch-list: patch-list;
            selected-index: selected-patch-index;

            patch-changed(patch_index) => {
                patch-changed(patch_index)
            }
        }

        MidiScroller {
            output: midi-display-values;
        }

        HorizontalLayout {
            Version {
                version: version;
            }

            VerticalSpacer { }

            SettingsIcon {
                open-settings => {
                    settings.show();
                }
            }
        }
    }
}
